{
  "name": "easywords-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:with-frontend": "cd ../UI && pnpm install && pnpm build && cd ../server && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@libsql/client": "^0.8.0",
    "@prisma/adapter-libsql": "^5.22.0",
    "@prisma/client": "5.22.0",
    "ai": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "edge-tts": "^1.0.1",
    "jose": "^6.2.2",
    "next": "^14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "playwright": "^1.58.2",
    "prisma": "^5.22.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
